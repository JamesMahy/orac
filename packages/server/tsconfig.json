{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2023",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./",
    "paths": {
      "@common/*": ["src/common/*"],
      "@database/*": ["src/prisma/*"],
      "@hosts/*": ["src/hosts/*"],
      "@projects/*": ["src/projects/*"],
      "@workspaces/*": ["src/workspaces/*"],
      "@ssh/*": ["src/ssh/*"],
      "@clankers/*": ["src/clankers/*"],
      "@vaults/*": ["src/vaults/*"],
      "@files/*": ["src/files/*"],
      "@helpers/config": ["src/helpers/config.helpers"],
      "@helpers/shell": ["src/helpers/shell.helpers"],
      "@users/*": ["src/users/*"],
      "@messages/*": ["src/messages/*"]
    },
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true
  },
  "include": ["src"]
}
