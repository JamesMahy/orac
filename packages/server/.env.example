# Database
DATABASE_URL=postgresql://user:password@localhost:5432/orac

# Server
PORT=3000
NODE_ENV=development

# Auth mode: 'single' (no login, hardcoded admin) or 'multi' (JWT login)
AUTH_MODE=single
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=changeme

# Encryption (64-character hex string = 32 bytes) — MUST be changed before first run
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=REPLACE_WITH_OUTPUT_OF_openssl_rand_-hex_32

# JWT signing secret (minimum 32 characters) — MUST be changed before first run
# Generate with: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_OUTPUT_OF_openssl_rand_-base64_48

# Session
SESSION_TIMEOUT_MINUTES=15

# SSH Configuration (all optional, sensible defaults)
SSH_KEEPALIVE_INTERVAL=60000
SSH_KEEPALIVE_COUNT_MAX=3
SSH_RECONNECT_BASE_MS=2000
SSH_RECONNECT_MAX_ATTEMPTS=3
SSH_TEST_TIMEOUT_MS=10000
SSH_EXEC_TIMEOUT_MS=30000
SSH_EXEC_MAX_OUTPUT_BYTES=1000000
SSH_MAX_CONCURRENT_CONNECTIONS=50
SSH_CONNECTION_IDLE_TIMEOUT_MS=300000

# CORS
CORS_ORIGIN=http://localhost:5173

# Cookie security (set to true in staging/prod without NODE_ENV=production)
# COOKIE_SECURE=true

# Swagger UI (enabled automatically when NODE_ENV != production; force-enable with:)
# SWAGGER_ENABLED=true

# RustFS (S3-compatible storage) — run via docker-compose.yml in dev
RUSTFS_ENDPOINT=http://localhost:9000
RUSTFS_BUCKET=orac
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
